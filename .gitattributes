# Note: Model files (*.pkl, *.pth) are generated by training scripts and ignored
# They should NOT be version controlled due to size and regeneration ability

# Ensure Unix line endings for shell scripts
mvnw text eol=lf
*.sh   text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Treat all Java / HTML / CSS as text
*.java  text
*.html  text
*.css   text
*.js    text
*.json  text
*.xml   text
*.yml   text
*.yaml  text
*.md    text
*.sql   text
*.py    text
